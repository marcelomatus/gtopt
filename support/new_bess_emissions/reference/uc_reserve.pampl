  1 * reserve_provision("provision_COLBUN_U1").up - 1 * reserve_provision("provision_COLBUN_U1").dn >= 0;

# PLEXOS Constraint 'COLBUN_U2_CPF_Simmetry': all 2 LHS term(s) provably contribute 0 at this run date (shadow Lines with Lin_Units=0, fully-offline Generators, or Fuel.offtake terms with no consuming generators).  Emitted as an inactive stub to preserve provenance; a follow-up run where the zeroed elements come online can flip active=True and restore the real LHS.  (File: DBSEN_PRGDIARIO.xml)
inactive constraint COLBUN_U2_CPF_Simmetry:
  0 >= 0;

