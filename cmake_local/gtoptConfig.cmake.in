#[=======================================================================[.rst:
gtoptConfig.cmake
-----------------

CMake package configuration file for the **gtopt** C++ library.

Generated by ``configure_package_config_file()``; installed alongside the
library under ``<prefix>/lib/cmake/gtopt-<version>/``.

Usage::

  find_package(gtopt REQUIRED)
  target_link_libraries(my_app PRIVATE gtopt::gtopt)

Dependencies
^^^^^^^^^^^^

The following packages must be findable on the consumer machine.  The
``cmake_local/`` subdirectory next to this file contains bundled Find modules
for the COIN-OR solver components.

* ``spdlog`` (≥ 1.12)
* ``Arrow`` (any version)
* ``Parquet`` (any version)
* ``Boost`` (≥ 1.70, component: ``container``)
* ``ZLIB``
* ``strong_type`` (rollbear, header-only)
* COIN-OR solver back-end: one of ``OsiClp`` (Clp), ``OsiCbc`` (Cbc), or
  ``OsiCpx`` (CPLEX).  The ``Solver.cmake`` in ``cmake_local/`` auto-detects
  which solver is available.

Note: if your project includes ``<gtopt/osi_solver.hpp>`` you also need
COIN-OR development headers installed on the build machine.

#]=======================================================================]

@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# ---- Standard dependencies ----

find_dependency(spdlog REQUIRED)
find_dependency(Arrow REQUIRED)
find_dependency(Parquet REQUIRED)
find_dependency(Boost REQUIRED COMPONENTS container)
find_dependency(ZLIB REQUIRED)
find_dependency(strong_type REQUIRED)

# daw_json_link is a header-only library used in the public gtopt/json/ headers.
# If not installed as a system package, consumers can pull it via CPM:
#   CPMAddPackage("gh:beached/daw_json_link@3.31.0")
find_dependency(daw QUIET)

# ---- COIN-OR solver ----
# Bundled Find modules allow consumers to discover the solver backend without
# needing to copy the custom Find*.cmake scripts themselves.
list(PREPEND CMAKE_MODULE_PATH "${CMAKE_CURRENT_LIST_DIR}/cmake_local")
set(COIN_SOLVER
    "AUTO"
    CACHE STRING "COIN-OR solver back-end (AUTO, CLP, CBC, CPX)"
)
include("${CMAKE_CURRENT_LIST_DIR}/cmake_local/Solver.cmake")

# ---- Exported targets ----
include("${CMAKE_CURRENT_LIST_DIR}/gtoptTargets.cmake")
