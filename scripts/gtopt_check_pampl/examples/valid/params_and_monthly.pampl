# =============================================================================
# Parameters and monthly values
# =============================================================================
#
# Demonstrates parameter declarations with both scalar and monthly-indexed
# values, used in constraint expressions.

# Scalar parameters
param emission_cap = 1000;
param penalty_cost = 50;

# Monthly demand scaling factors (Jan=low, Jul-Aug=peak, Dec=low)
param demand_scale[month] = [0.8, 0.85, 0.9, 0.95, 1.0, 1.1,
                              1.2, 1.2, 1.0, 0.95, 0.9, 0.8];

# Monthly renewable availability (higher in summer)
param solar_factor[month] = [0.4, 0.5, 0.6, 0.7, 0.8, 0.9,
                              0.95, 0.9, 0.8, 0.65, 0.5, 0.4];

# Use parameters in constraints
constraint emission_limit "Annual emission constraint":
  generator('Coal1').generation + generator('Coal2').generation <= emission_cap;

# Negative parameter values
param min_reserve = -10;
