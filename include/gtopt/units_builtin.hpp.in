/**
 * @file      units_builtin.hpp  (generated from units_builtin.hpp.in)
 * @brief     Compiled-in fallback copy of share/gtopt/unit_dialects.json
 * @copyright BSD-3-Clause
 *
 * Generated by CMake at configure time from
 * `share/gtopt/unit_dialects.json`.  Do NOT edit this file directly —
 * edit the JSON source and reconfigure.  The fallback exists so the
 * registry always has a working dictionary even when no external
 * unit_dialects.json is installed (tests, standalone builds, library
 * consumers without our install layout).
 */

#pragma once

#include <string_view>

namespace gtopt
{

/// Absolute path baked at configure time from
/// `${CMAKE_INSTALL_FULL_DATADIR}/gtopt/unit_dialects.json`.  Empty if
/// the install dir was not resolvable at configure time.
inline constexpr std::string_view kInstalledUnitsFilePath =
    "@GTOPT_UNIT_DIALECTS_INSTALL_PATH@";

/// Absolute path to the in-tree source copy (works when running from
/// the build directory of a checked-out source tree).
inline constexpr std::string_view kSourceUnitsFilePath =
    "@GTOPT_UNIT_DIALECTS_SOURCE_PATH@";

/// Compiled-in JSON content — bit-for-bit copy of the shipped
/// `share/gtopt/unit_dialects.json` at configure time.  The raw-string
/// delimiter is `gtopt_units_v1` to avoid any collision with the JSON
/// body.
inline constexpr std::string_view kBuiltinUnitsJson =
    R"gtopt_units_v1(@GTOPT_UNIT_DIALECTS_JSON_CONTENT@)gtopt_units_v1";

}  // namespace gtopt
