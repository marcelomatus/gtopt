# PLEXOS Constraint 'CTFOFF_CELCO_BL2': reserve provision [MW] ≥ 0 (File: DBSEN_PRGDIARIO.xml)
constraint CTFOFF_CELCO_BL2:
  -1 * reserve_provision("provision_CELCO_BL2").up >= 0;

# PLEXOS Constraint 'CTFOFF_CHOLGUAN_BL2': reserve provision [MW] ≥ 0 (File: DBSEN_PRGDIARIO.xml)
constraint CTFOFF_CHOLGUAN_BL2:
  -1 * reserve_provision("provision_CHOLGUAN_BL2").up >= 0;

# PLEXOS Constraint 'CTFOFF_CIPRESES_U1': Σ reserve provision [MW] + commitment shutdown [0/1] ≤ 35 — active=False (excluded from PLEXOS ST schedule / contingency row) (File: DBSEN_PRGDIARIO.xml)
inactive constraint CTFOFF_CIPRESES_U1:
  1 * reserve_provision("provision_CIPRESES_U1").up + 35 * commitment("uc_CIPRESES_U1").shutdown <= 35;

# PLEXOS Constraint 'CTFOFF_CIPRESES_U1_T2': Σ reserve provision [MW] + decision variable ≤ 35 — active=False (excluded from PLEXOS ST schedule / contingency row) (File: DBSEN_PRGDIARIO.xml)
inactive constraint CTFOFF_CIPRESES_U1_T2:
  1 * reserve_provision("provision_CIPRESES_U1").up + 35 * decision_variable("OFF_T2_CIPRESES_U1").value <= 35;

# PLEXOS Constraint 'CTFOFF_CIPRESES_U1_T2def': commitment shutdown [0/1] ≥ 0 — active=False (excluded from PLEXOS ST schedule / contingency row) (File: DBSEN_PRGDIARIO.xml)
inactive constraint CTFOFF_CIPRESES_U1_T2def:
  -1 * commitment("uc_CIPRESES_U1").shutdown >= 0;

# PLEXOS Constraint 'CTFOFF_CIPRESES_U2': Σ reserve provision [MW] + commitment shutdown [0/1] ≤ 31 — active=False (excluded from PLEXOS ST schedule / contingency row) (File: DBSEN_PRGDIARIO.xml)
