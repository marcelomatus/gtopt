# cmake_uninstall.cmake.in
# Generated by CMake — do not edit.
#
# Removes every file that was recorded in the install manifest when
# `cmake --install` (or `cmake --build --target install`) was last run.
#
# Usage (called by the `uninstall` CMake target):
#   cmake -P <build_dir>/cmake_uninstall.cmake
#
# Respects $ENV{DESTDIR}: if DESTDIR was set during installation, set the same
# value here so that the correct absolute path is reconstructed.

set(_manifest "@CMAKE_CURRENT_BINARY_DIR@/install_manifest.txt")

if(NOT EXISTS "${_manifest}")
  message(FATAL_ERROR
    "Cannot find install manifest: ${_manifest}\n"
    "Run 'cmake --install <build_dir>' first, then re-run the uninstall target.")
endif()

file(READ "${_manifest}" _files)
string(REGEX REPLACE "\n" ";" _files "${_files}")

foreach(_file ${_files})
  set(_full "$ENV{DESTDIR}${_file}")
  if(IS_SYMLINK "${_full}" OR EXISTS "${_full}")
    message(STATUS "Uninstalling: ${_full}")
    execute_process(
      COMMAND "@CMAKE_COMMAND@" -E rm -f "${_full}"
      RESULT_VARIABLE _rm_result
    )
    if(NOT _rm_result EQUAL 0)
      message(SEND_ERROR "Failed to remove: ${_full}")
    endif()
  else()
    message(STATUS "Already removed (skipping): ${_full}")
  endif()
endforeach()
