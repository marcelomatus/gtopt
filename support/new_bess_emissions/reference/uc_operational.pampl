constraint discharge_ELTOROmax:
  0.216647 * generator("EL_TORO_U1").generation + 0.216647 * generator("EL_TORO_U2").generation + 0.216647 * generator("EL_TORO_U3").generation + 0.216647 * generator("EL_TORO_U4").generation <= 112.302;
