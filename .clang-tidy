---
# Only apply to C++ files (exclude Python and CMake files)
#
# Disabled-check rationale (groups):
#   altera-*, llvmlibc-*        – domain-specific (FPGA / LLVM libc); not relevant
#   fuchsia-*                   – Fuchsia OS style; conflicts with project conventions
#   llvm-header-guard,          – project uses #pragma once
#   portability-avoid-pragma-once
#   llvm-include-order          – project clang-format handles include ordering
#   llvm-namespace-comment,     – project already writes }  // namespace gtopt comments
#   google-readability-namespace-comments,
#   llvm-namespace-comment
#   google-build-using-namespace – 'using namespace' in .cpp TU scope is accepted
#   google-readability-casting  – project uses C++ casts; extra verbosity not required
#   modernize-use-trailing-return-type – project uses both styles; not enforced
#   modernize-macro-to-enum,    – COIN-OR and other deps rely on C macros
#   cppcoreguidelines-macro-*
#   misc-multiple-inheritance,  – deliberately used in the codebase
#   misc-non-private-member-variables-in-classes – structs with public members are idiomatic
#   misc-include-cleaner        – too aggressive; third-party transitive includes common
#   misc-confusable-identifiers – false-positive-prone; math code uses i/j/l variables
#   readability-magic-numbers,  – LP coefficients (0.0, 1.0, 0.5) are self-documenting
#   cppcoreguidelines-avoid-magic-numbers
#   readability-identifier-length  – single-char vars are idiomatic in LP/math code
#   readability-identifier-naming  – project has its own naming conventions
#   readability-function-cognitive-complexity – subjective; not enforced
#   readability-redundant-member-init – project uses explicit {} init for clarity
#   bugprone-easily-swappable-parameters – too noisy in LP/math API functions
#   bugprone-derived-method-shadowing-base-method – false positives in templates
#   bugprone-lambda-function-name – __func__ in lambdas; harmless pattern
#   cppcoreguidelines-pro-bounds-avoid-unchecked-container-access – []  preferred
#                                  over .at() in hot LP-assembly paths
#   clang-analyzer-{cplusplus.NewDeleteLeaks, – false positives with COIN-OR
#     security.ArrayBound,
#     core.uninitialized.UndefReturn,
#     unix.Stream}
#   clang-diagnostic-{c2y-extensions,          – compiler-version noise; not actionable
#     constexpr-local-var-non-literal-type,
#     deprecated-declarations,
#     template-param-default-arg-redefinition}
#   llvm-prefer-static-over-anonymous-namespace – misc-use-anonymous-namespace
#                                  (enabled) takes the opposite, preferred stance
#   illegal-initializer-type    – Clang-specific; no violations in codebase
Checks: "*,\
  misc-include-cleaner,\
  -altera-*,\
  -boost-use-ranges,\
  -bugprone-derived-method-shadowing-base-method,\
  -bugprone-easily-swappable-parameters,\
  -bugprone-lambda-function-name,\
  -clang-analyzer-core.uninitialized.UndefReturn,\
  -clang-analyzer-cplusplus.NewDeleteLeaks,\
  -clang-analyzer-security.ArrayBound,\
  -clang-analyzer-unix.Stream,\
  -clang-diagnostic-c2y-extensions,\
  -clang-diagnostic-constexpr-local-var-non-literal-type,\
  -clang-diagnostic-deprecated-declarations,\
  -clang-diagnostic-template-param-default-arg-redefinition,\
  -cppcoreguidelines-avoid-magic-numbers,\
  -cppcoreguidelines-macro-to-enum,\
  -cppcoreguidelines-macro-usage,\
  -cppcoreguidelines-pro-bounds-avoid-unchecked-container-access,\
  -fuchsia-default-arguments-calls,\
  -fuchsia-default-arguments-declarations,\
  -fuchsia-multiple-inheritance,\
  -fuchsia-overloaded-operator,\
  -fuchsia-statically-constructed-objects,\
  -fuchsia-trailing-return,\
  -google-build-using-namespace,\
  -google-readability-casting,\
  -google-readability-namespace-comments,\
  -illegal-initializer-type,\
  -llvm-header-guard,\
  -llvm-include-order,\
  -llvm-namespace-comment,\
  -llvm-prefer-static-over-anonymous-namespace,\
  -llvmlibc-*,\
  -misc-confusable-identifiers,\
  -misc-include-cleaner,\
  -misc-multiple-inheritance,\
  -misc-non-private-member-variables-in-classes,\
  -modernize-macro-to-enum,\
  -modernize-use-trailing-return-type,\
  -portability-avoid-pragma-once,\
  -readability-function-cognitive-complexity,\
  -readability-identifier-length,\
  -readability-identifier-naming,\
  -readability-magic-numbers,\
  -readability-redundant-member-init\
  "

HeaderFilterRegex: '.*'
SystemHeaders: false

WarningsAsErrors: ''
CheckOptions:
  - key: performance-move-const-arg.CheckTriviallyCopyableMove
    value: true
  - key: bugprone-use-after-move.IgnoreUnnamedTypes
    value: false
  - key: bugprone-use-after-move.IgnorePartialMoves
    value: false
  - key: hicpp-invalid-access-moved.IgnoreUnnamedTypes
    value: false
  - key: hicpp-invalid-access-moved.IgnorePartialMoves
    value: false
  - key: 'bugprone-argument-comment.StrictMode'
    value: 'true'
# Prefer using enum classes with 2 values for parameters instead of bools
  - key: 'bugprone-argument-comment.CommentBoolLiterals'
    value: 'true'
  - key: 'bugprone-misplaced-widening-cast.CheckImplicitCasts'
    value: 'true'
  - key: 'bugprone-sizeof-expression.WarnOnSizeOfIntegerExpression'
    value: 'true'
  - key: 'bugprone-suspicious-string-compare.WarnOnLogicalNotComparison'
    value: 'true'
  - key: 'readability-simplify-boolean-expr.ChainedConditionalReturn'
    value: 'true'
  - key: 'readability-simplify-boolean-expr.ChainedConditionalAssignment'
    value: 'true'
  - key: 'readability-uniqueptr-delete-release.PreferResetCall'
    value: 'true'
  - key: 'cppcoreguidelines-init-variables.MathHeader'
    value: '<cmath>'
  - key: 'cppcoreguidelines-narrowing-conversions.PedanticMode'
    value: 'true'
  - key: 'readability-else-after-return.WarnOnUnfixable'
    value: 'true'
  - key: 'readability-else-after-return.WarnOnConditionVariables'
    value: 'true'
  - key: 'readability-inconsistent-declaration-parameter-name.Strict'
    value: 'true'
  - key: 'readability-qualified-auto.AddConstToQualified'
    value: 'true'
  - key: 'readability-redundant-access-specifiers.CheckFirstDeclaration'
    value: 'true'
...
