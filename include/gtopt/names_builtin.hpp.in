/**
 * @file      names_builtin.hpp  (generated from names_builtin.hpp.in)
 * @brief     Compiled-in fallback copy of share/gtopt/names.json
 * @copyright BSD-3-Clause
 *
 * Generated by CMake at configure time from
 * `share/gtopt/names.json`. Do NOT edit this file directly — edit
 * the JSON source and reconfigure. The fallback exists so the
 * registry always has a working dictionary even when no external
 * names.json is installed (tests, standalone builds, library
 * consumers without our install layout).
 *
 * Also bakes in the absolute path that the install rule would use,
 * so `find_names_file()` can probe it without environment-dependent
 * heuristics.
 */

#pragma once

#include <string_view>

namespace gtopt
{

/// Absolute path baked at configure time from
/// `${CMAKE_INSTALL_FULL_DATADIR}/gtopt/names.json`. Empty if
/// the install dir was not resolvable at configure time.
inline constexpr std::string_view kInstalledNamesFilePath =
    "@GTOPT_NAMES_INSTALL_PATH@";

/// Absolute path to the in-tree source copy (works when running
/// from the build directory of a checked-out source tree).
inline constexpr std::string_view kSourceNamesFilePath =
    "@GTOPT_NAMES_SOURCE_PATH@";

/// Compiled-in JSON content — bit-for-bit copy of the shipped
/// `share/gtopt/names.json` at configure time. The raw-string
/// delimiter is `gtopt_names_v1` to avoid any collision with the
/// JSON body.
inline constexpr std::string_view kBuiltinNamesJson =
    R"gtopt_names_v1(@GTOPT_NAMES_JSON_CONTENT@)gtopt_names_v1";

}  // namespace gtopt
